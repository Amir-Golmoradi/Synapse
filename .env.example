SYNAPSE_SERVICE_HOST_PORT=8080
SYNAPSE_SERVICE_CONTAINER_PORT=8080

POSTGRES_IMAGE=postgres:18-alpine
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse-local-password
POSTGRES_HOST_PORT=5432
POSTGRES_CONTAINER_PORT=5432

REDIS_IMAGE=redis:8-alpine
REDIS_HOST_PORT=6379
REDIS_CONTAINER_PORT=6379

GOOGLE_CLIENT_ID=synapse-local-google-client
GOOGLE_CLIENT_SECRET=synapse-local-google-secret
GOOGLE_TOKEN_INFO_URL=https://oauth2.googleapis.com/tokeninfo?id_token={token}

JWT_SECRET=synapse-local-development-secret-synapse-local-development-secret
